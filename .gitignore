# --- SMART & SAFE .GITIGNORE FOR TARATARA PROJECT ---

# [1. DEPENDENCIES] - Node modules are heavy and can be re-installed using 'npm install'
node_modules/
**/node_modules/

# [2. BUILD & PRODUCTION] - These are generated files, not source code
dist/
build/
out/
.next/
**/dist/
**/build/
**/out/
**/.next/

# [3. SECRETS & ENVIRONMENT] - NEVER commit these to GitHub (Security Risk!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env*

# [4. LOGS & TEMPORARY FILES] - Useful for debugging but not for GitHub
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
err.log
output.txt
.cache/
.eslintcache
.parcel-cache
.turbo/

# [5. IDE & EDITORS] - Personal settings for VS Code, WebStorm, etc.
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# [6. OPERATING SYSTEM FILES] - System-generated garbage
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# [7. PROJECT SPECIFIC SCRATCH FILES] - Temporary scripts
Backend/scratch_*.js
Backend/output.txt

# [8. UPLOADS / ASSETS] - Ignore if these are user-uploaded files
# uploads/
# public/uploads/
